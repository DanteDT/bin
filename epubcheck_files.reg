Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\Directory\shell\EpubCheck]
@="EpubChecks"
"Icon"="C:\\bin\\epubcheck_files.ico"

[HKEY_CLASSES_ROOT\Directory\shell\EpubCheck\command]
@="powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\bin\\epubcheck_files.ps1\" \"%1\""
